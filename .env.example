# Certificate Issuer — Environment Variables
# Copy this file to .env.local for local development.
# Do NOT commit .env.local or any real private keys to version control.

# ---------------------------------------------------------------------------
# DID Certificate Issuance (ecdsa-sd-2023 / did:web)
# ---------------------------------------------------------------------------
# These variables configure the DID key pair used to cryptographically sign
# W3C Verifiable Credentials.  Without them the app still works but credentials
# are issued as unsigned drafts.
#
# How to generate a key pair (requires @trustvc/w3c-issuer):
#
#   node -e "
#     const { generateKeyPair } = require('@trustvc/w3c-issuer');
#     generateKeyPair({ type: 'ecdsa-sd-2023' }).then(kp => {
#       console.log('PUBLIC :', kp.publicKeyMultibase);
#       console.log('PRIVATE:', kp.secretKeyMultibase);
#     });
#   "
#
# ⚠️  SECURITY NOTE: NEXT_PUBLIC_* variables are bundled into the static JS
#     files served by GitHub Pages.  Anyone who downloads the page can read
#     them.  Use this only for demo or test keys that carry no real-world
#     value. For production, use a backend signing service instead.

# Full DID key URL, e.g. did:web:lanlan3322.github.io:certificate-issuer#key-1
NEXT_PUBLIC_DID_KEY_ID=

# DID controller (the DID document subject)
NEXT_PUBLIC_DID_CONTROLLER=did:web:lanlan3322.github.io:certificate-issuer

# Multibase-encoded ECDSA secp256k1 public key (starts with "z")
NEXT_PUBLIC_DID_PUBLIC_KEY_MULTIBASE=

# Multibase-encoded ECDSA secp256k1 private key (starts with "z")
# ⚠️  Keep this secret — see the security note above.
NEXT_PUBLIC_DID_PRIVATE_KEY_MULTIBASE=

# ---------------------------------------------------------------------------
# Ethereum / Document Store
# ---------------------------------------------------------------------------
# The app uses MetaMask (injected web3 provider) for Ethereum signing.
# No private key is stored here — the user's wallet signs on-chain transactions.

# Sepolia testnet document store contract address.
# Deploy your own: https://docs.tradetrust.io/docs/how-tos/deployment
# The default below is a demo store — it does NOT accept outside issuers.
NEXT_PUBLIC_DOCUMENT_STORE_ADDRESS=0x4B30674f8F77C0b1aB4c8A34B2a85C295A3aE2D4

# ---------------------------------------------------------------------------
# Optional: Ethereum RPC (used only if you add server-side or API-route code)
# ---------------------------------------------------------------------------
# ETH_RPC_URL=https://rpc.sepolia.org
